{
  "name": "template-vite-react",
  "private": true,
  "version": "0.0.0-semantic-release",
  "license": "MIT",
  "description": "Boilerplate for React + Vite project",
  "homepage": "https://github.com/aquia-inc/template-vite-react#readme",
  "bugs": {
    "url": "https://github.com/aquia-inc/template-vite-react/issues"
  },
  "author": "Aquia, Inc.",
  "contributors": [
    "Sinan Bolel"
  ],
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "engines": {
    "node": "24",
    "npm": "please-use-yarn",
    "yarn": "4.14.1"
  },
  "scripts": {
    "start": "yarn run dev",
    "setup": "node ./scripts/setup.mjs",
    "doctor": "node ./scripts/doctor.mjs",
    "dev": "vite",
    "dev:e2e": "vite --mode test --host 127.0.0.1 --port 4173 --strictPort",
    "build": "tsc -p tsconfig.prod.json && vite build --mode production",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "init:template": "node scripts/init-template.mjs",
    "test": "NODE_ENV=test jest --coverage --colors --maxWorkers=50%",
    "test:precommit": "NODE_ENV=test jest --onlyChanged --coverage --colors --watch=false --maxWorkers=50%",
    "test:watch": "NODE_ENV=test jest --onlyChanged --coverage --colors --watch --maxWorkers=25%",
    "test:ci": "NODE_ENV=test jest --ci --all  --coverage --colors --maxWorkers=100%",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "ci": "run-p 'lint:js' 'lint:other' 'test:ci'",
    "lint": "run-p 'lint:js' 'lint:other'",
    "lint:js": "eslint . --cache --max-warnings=0",
    "lint:other": "prettier --check . --ignore-path .gitignore --ignore-path .prettierignore",
    "fix": "run-s 'fix:js' 'fix:other'",
    "fix:js": "eslint . --cache --fix",
    "fix:other": "prettier --write . --ignore-path .gitignore --ignore-path .prettierignore",
    "semantic-release": "semantic-release",
    "postinstall": "yarn run prepare",
    "prepare": "husky",
    "sb": "yarn run storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^9.0.1",
    "@mui/lab": "^9.0.0-beta.3",
    "@mui/material": "^9.0.1",
    "@mui/x-data-grid": "^9.1.0",
    "@popperjs/core": "^2.11.8",
    "aws-amplify": "^6.17.0",
    "classnames": "^2.5.1",
    "clipboard-copy": "^4.0.1",
    "lodash": "^4.18.1",
    "react": "^19.2.6",
    "react-animate-height": "^3.2.4",
    "react-cookie": "^8.1.2",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-helmet": "^6.1.0",
    "react-hook-form": "^7.76.0",
    "react-router-dom": "^7.15.1",
    "uswds": "^2.14.0",
    "uuid": "^14.0.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rolldown/binding-wasm32-wasi": "^1.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-links": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "24.12.4",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/react-helmet": "^6.1.11",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@types/uuid": "^11.0.0",
    "@unrs/resolver-binding-wasm32-wasi": "1.12.2",
    "@vitejs/plugin-react": "^6.0.2",
    "camelcase": "9.0.0",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-date-mock": "^1.0.10",
    "jest-environment-jsdom": "^30.4.1",
    "jest-environment-node": "^30.4.1",
    "jest-fetch-mock": "^3.0.3",
    "jest-watch-typeahead": "^3.0.1",
    "lint-staged": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "prop-types": "^15.8.1",
    "react-docgen-typescript": "^2.4.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.100.0",
    "semantic-release": "^25.0.3",
    "source-map-explorer": "^2.5.3",
    "storybook": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.0.16",
    "web-vitals": "^5.3.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": [
      "eslint --cache --fix",
      "prettier --write"
    ],
    "**/*.{css,html,json,md,mdx,scss,yaml,yml}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "restricted"
  },
  "release": {
    "private": true,
    "branches": [
      "main"
    ],
    "tagFormat": "v${version}",
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "dist",
              "label": "Distribution"
            },
            {
              "path": "CHANGELOG.md",
              "label": "Changelog"
            },
            {
              "path": "README.md",
              "label": "Readme"
            }
          ]
        }
      ]
    ],
    "preset": "conventionalcommits"
  }
}
